<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>貫坊首席 | 日誌系統</title>
    <style>
        :root {
            --bg: #f8f8f8;
            --white: #ffffff;
            --black: #000000;
            --gray: #999999;
            --line: #eeeeee;
        }

        body {
            font-family: -apple-system, "Noto Sans TC", sans-serif;
            background-color: var(--bg);
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
        }

        .container {
            width: 100%;
            max-width: 500px; /* 針對 Pro Max 優化 */
            background: var(--white);
            padding: 40px 25px;
            border-radius: 24px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.02);
            box-sizing: border-box;
        }

        h2 {
            text-align: center;
            letter-spacing: 5px;
            font-weight: 600;
            margin: 0 0 30px 0;
            font-size: 20px;
        }

        label {
            display: block;
            font-size: 12px;
            color: var(--gray);
            margin: 25px 0 8px 5px;
            letter-spacing: 2px;
        }

        /* 輸入框與選單 - iPhone 圓潤感 */
        select, input {
            width: 100%;
            padding: 16px;
            border: 1px solid var(--line);
            border-radius: 12px;
            font-size: 16px;
            background: #fff;
            box-sizing: border-box;
            outline: none;
            -webkit-appearance: none;
        }

        .input-group {
            display: flex;
            gap: 10px;
            margin-bottom: 10px;
        }

        /* 新增按鈕 */
        .btn-add {
            background: #f0f0f0;
            border: none;
            padding: 0 20px;
            border-radius: 12px;
            font-weight: 600;
            white-space: nowrap;
            cursor: pointer;
        }

        /* 列表容器 */
        .list-box {
            background: #fafafa;
            border-radius: 12px;
            min-height: 45px;
            padding: 5px 0;
            border: 1px solid #f2f2f2;
        }

        /* 每行紀錄樣式 - 加上符號 */
        .item {
            display: flex;
            padding: 12px 15px;
            border-bottom: 1px solid #f0f0f0;
            font-size: 15px;
            align-items: center;
        }
        .item:last-child { border-bottom: none; }
        
        /* 首席要求的符號標示 */
        .symbol {
            margin-right: 10px;
            font-weight: bold;
            color: var(--black);
        }

        .todo-item { cursor: pointer; }
        .todo-item.done span {
            text-decoration: line-through;
            color: #ccc;
        }

        /* LINE 按鈕 - 高級黑 */
        .btn-line {
            display: block;
            background: var(--black);
            color: #fff;
            text-align: center;
            padding: 18px;
            border-radius: 15px;
            text-decoration: none;
            margin-top: 40px;
            font-weight: 600;
            letter-spacing: 3px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

        .hint { text-align: center; color: #ccc; padding: 12px; font-size: 13px; }
    </style>
</head>
<body>

<div class="container">
    <h2>貫坊首席 日誌系統</h2>

    <label>DATE</label>
    <input type="date" id="logDate" onchange="changeDate()">

    <label>STAFF</label>
    <select id="staff" onchange="saveStaff()">
        <option value="貫坊首席">貫坊首席</option>
        <option value="小魚老師">小魚老師</option>
        <option value="南南老師">南南老師</option>
    </select>

    <label>WORK LOG</label>
    <div class="input-group">
        <input type="text" id="workIn" placeholder="輸入內容...">
        <button class="btn-add" onclick="doAddWork()">新增</button>
    </div>
    <div id="workList" class="list-box"></div>

    <label>CHECKLIST</label>
    <div class="input-group">
        <input type="text" id="todoIn" placeholder="待辦項目...">
        <button class="btn-add" onclick="doAddTodo()">新增</button>
    </div>
    <div id="todoList" class="list-box"></div>

    <a href="javascript:void(0)" class="btn-line" onclick="sendToLine()">上傳至 LINE 群組</a>
</div>

<script>
    let db = { works: [], todos: [] };

    window.onload = function() {
        // 預設日期
        document.getElementById('logDate').valueAsDate = new Date();
        // 記憶員工
        const s = localStorage.getItem('kf_staff');
        if(s) document.getElementById('staff').value = s;
        refresh();
    };

    function saveStaff() {
        localStorage.setItem('kf_staff', document.getElementById('staff').value);
    }

    function getKey() {
        return 'kf_data_' + document.getElementById('logDate').value;
    }

    function changeDate() { refresh(); }

    function refresh() {
        const data = localStorage.getItem(getKey());
        db = data ? JSON.parse(data) : { works: [], todos: [] };
        
        // 渲染工作紀錄
        const wBox = document.getElementById('workList');
        wBox.innerHTML = db.works.length ? db.works.map(w => `
            <div class="item"><span class="symbol">√</span><span>${w}</span></div>
        `).join('') : '<div class="hint">尚未輸入紀錄</div>';

        // 渲染待辦事項
        const tBox = document.getElementById('todoList');
        tBox.innerHTML = db.todos.length ? db.todos.map((t, i) => `
            <div class="item todo-item ${t.done?'done':''}" onclick="toggleTodo(${i})">
                <span class="symbol">${t.done?'√':'◦'}</span>
                <span>${t.text}</span>
            </div>
        `).join('') : '<div class="hint">尚未輸入待辦</div>';
    }

    function doAddWork() {
        const val = document.getElementById('workIn').value.trim();
        if(!val) return;
        db.works.push(val);
        document.getElementById('workIn').value = '';
        saveAndShow();
    }

    function doAddTodo() {
        const val = document.getElementById('todoIn').value.trim();
        if(!val) return;
        db.todos.push({text: val, done: false});
        document.getElementById('todoIn').value = '';
        saveAndShow();
    }

    function toggleTodo(i) {
        db.todos[i].done = !db.todos[i].done;
        // 自動連動：勾選完畢加到紀錄
        if(db.todos[i].done) {
            db.works.push("[完成] " + db.todos[i].text);
        } else {
            const idx = db.works.indexOf("[完成] " + db.todos[i].text);
            if(idx > -1) db.works.splice(idx, 1);
        }
        saveAndShow();
    }

    function saveAndShow() {
        localStorage.setItem(getKey(), JSON.stringify(db));
        refresh();
    }

    function sendToLine() {
        if(!db.works.length && !db.todos.length) return alert("請先輸入內容");
        const staff = document.getElementById('staff').value;
        const date = document.getElementById('logDate').value.split('-').slice(1).join('/');
        
        const wMsg = db.works.map(w => `√ ${w.replace('[完成] ','')}`).join('\n');
        const tMsg = db.todos.map(t => `${t.done?'✅':'⬜'} ${t.text}`).join('\n');

        const msg = `【LKF彩顏 | 工作彙報】\n人員：${staff}\n日期：${date}\n\n📍 工作內容：\n${wMsg}\n\n📝 待辦進度：\n${tMsg}`;
        window.location.href = `https://line.me/R/msg/text/?${encodeURIComponent(msg)}`;
    }
</script>

</body>
</html>
